# Copy to .env (lobes init does this) and adjust. Consumed by docker-compose.yml.
# This configures the local vLLM model lobes runs — the model the lobes
# agent consumes over the acp `vllm-local` provider.

# HuggingFace token. Required only if the model repo is gated — accept its
# license on huggingface.co first, then paste a read token here.
# SECURITY: the default primary serves with --trust-remote-code (it ships custom
# modeling code), which runs in-container with access to this token. The default
# checkpoints are public, so leave HF_TOKEN empty; if you must set one for a gated
# repo, use a minimal-scope read-only token and clear it once weights are cached.
HF_TOKEN=

# Model to download/serve, and the name clients address it by. VLLM_SERVED_NAME
# MUST equal the part after `vllm-local/` in the culture.yaml `model:`
# field, or the acp `vllm-local` provider won't resolve the model. When exposing
# the API publicly you can set VLLM_SERVED_NAME to a generic alias (e.g. `default`)
# to keep the backend checkpoint name out of the public `GET /v1/models`.
VLLM_MODEL=sakamakismile/Qwen3.6-27B-Text-NVFP4-MTP
VLLM_SERVED_NAME=sakamakismile/Qwen3.6-27B-Text-NVFP4-MTP

# Host port for the OpenAI-compatible API.
VLLM_PORT=8000

# Bearer key for the OpenAI-compatible API. Empty (default) leaves local dev open;
# set it and vLLM requires `Authorization: Bearer $CULTURE_VLLM_API_KEY` on every
# request. This is the GATE for any public exposure — set a strong random value
# BEFORE running `lobes tunnel`. SECURITY: never commit a real key; it lives only
# in this .env (chmod 0600, gitignored).
CULTURE_VLLM_API_KEY=

# Context window. Qwen3.6-27B is 262144 (256K) native, and that is the served
# default here (load-tested 2026-06-03 on the shared GB10: ~70 GiB resident at util
# 0.6 — the SAME footprint as 32K/128K, because --gpu-memory-utilization fixes the
# KV-pool reservation; only the addressable context grows). vLLM reports 5.3x max
# concurrency at a full 256K request, well above the seqs=2 decode cap, so no
# practical concurrency loss. Lower it only if you need headroom for heavier
# co-resident mesh agents.
VLLM_MAX_MODEL_LEN=262144

# Fraction of the 128 GB unified memory vLLM may reserve. Lower leaves headroom
# for the OS and other mesh agents; raise toward 0.85 on a dedicated box.
# `lobes switch --machine` sets this from the machine profile (spark 0.6 shared,
# blackwell 0.85 dedicated). Override with `lobes switch --gpu-mem-util`.
VLLM_GPU_MEM_UTIL=0.6

# --- Tuning profile (purpose + machine) -----------------------------------
# The active gear: which serving purpose and machine `lobes switch` last resolved.
# Recorded for the read-only verbs (status / whoami / overview) and read by
# `lobes benchmark` (which defaults its workload shape to VLLM_PURPOSE). Set by
# `lobes switch --purpose {balanced,prompt-heavy,decode-heavy} --machine
# {auto,spark,thor,blackwell,generic}`. See docs/tuning-profiles.md.
VLLM_PURPOSE=balanced
VLLM_MACHINE=spark

# vLLM attention kernel. flashinfer is the Blackwell-class backend shipped in the
# nv26.04 image; `lobes switch --machine` writes it from the machine profile.
VLLM_ATTENTION_BACKEND=flashinfer

# vLLM --max-num-seqs (concurrent decode slots) and --max-num-batched-tokens
# (prefill chunk budget). Capped at 2 for the MTP primary (4 OOMs at n=3/high
# context). `lobes switch --purpose` tunes --max-num-batched-tokens and (for
# non-MTP models) --max-num-seqs: balanced 4/8192, prompt-heavy 4/16384,
# decode-heavy 8/4096; switching to the MTP primary forces 2.
VLLM_MAX_NUM_SEQS=2
VLLM_MAX_NUM_BATCHED_TOKENS=8192

# Compose serve extras:
#  * MTP default primary (sakamakismile/Qwen3.6-27B-Text-NVFP4-MTP) — its four
#    serve flags are baked into docker-compose.yml `command:` so the default
#    deploys out of the box: `--speculative-config
#    '{"method":"qwen3_5_mtp","num_speculative_tokens":3}' --trust-remote-code
#    --language-model-only --tokenizer=mmangkad/Qwen3.6-27B-NVFP4`. They are
#    MTP-only — to serve a NON-MTP model, REMOVE those 4 lines from compose
#    (`lobes switch <non-mtp-model>` prints them). The --tokenizer override is
#    required (the checkpoint's tokenizer_config declares TokenizersBackend,
#    absent from nv26.04). See docs/qwen3.6-27b-text-nvfp4-mtp.md.
#  * MoE (Qwen3.6-35B-A3B): add `--moe-backend=marlin` to compose by hand
#    (verified to load the 35B solo on the GB10) — NOT a default (compose can't
#    conditionally omit a flag). `lobes switch` prints the exact line. See
#    docs/qwen3.6-35b-a3b-nvfp4.md.

# OpenAI tool-call parser (used with --enable-auto-tool-choice). Qwen3-Coder /
# Qwen3.6 checkpoints (e.g. Qwen3.6-27B) emit the XML function format and need
# `qwen3_coder` (or `qwen3_xml`); `hermes` fits Qwen3 dense models (e.g. Qwen3-32B,
# which emit Hermes-style JSON tool calls). `lobes switch` auto-selects an
# appropriate parser per model and writes it here; override with `--tool-call-parser`.
VLLM_TOOL_CALL_PARSER=qwen3_coder

# vLLM --quantization for the NVFP4 weights. `modelopt_fp4` fits the nvidia/ and
# mmangkad/ (ModelOpt) checkpoints; RedHatAI NVFP4 (e.g.
# RedHatAI/Mistral-Small-3.2-24B-Instruct-2506-NVFP4) is `compressed-tensors`; the
# sakamakismile MTP re-export uses plain `modelopt` (native SM120 path).
# `lobes switch` writes this from the catalog (override with `--quantization`).
VLLM_QUANTIZATION=modelopt

# vLLM --kv-cache-dtype. fp8 needs calibrated k_scale/v_scale baked into the
# checkpoint; the default primary's NVFP4 re-export ships none
# (kv_cache_quant_algo: null), which trips `assert layer.k_scale > 0.0` on
# hardware/builds where fp8 KV isn't tolerated without those scales. The
# shipped default STAYS fp8 (GB10 behavior unchanged) — set to `auto` on a
# machine where fp8 KV faults for the served checkpoint (e.g. a Jetson Thor,
# sm_110 — see agentculture/lobes-cli#109).
VLLM_KV_CACHE_DTYPE=fp8

# Host path for the HuggingFace weight cache. Defaults to ~/.cache/huggingface
# (or /root/.cache/huggingface if $HOME is unset). Set to reuse an existing cache
# or to pin a specific disk.
HF_CACHE=

# Host dir for durable, restart-surviving logs (issue #50). The vLLM service tees
# its stdout+stderr here as per-boot files (vllm-<boot>.log) via mg-logwrap, so a
# crash trace survives container restart/recreate. Read them with `lobes logs`.
# Default ./logs next to docker-compose.yml; set an absolute path to pin a disk.
MODEL_GEAR_LOG_DIR=
