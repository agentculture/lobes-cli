
# === Audio overlay (lobes init --fleet --audio) ============================
# Appended to .env when you scaffold with --audio. Consumed by
# docker-compose.audio.yml: Chatterbox TTS + Parakeet STT + the realtime
# bridge, fronted by the same gateway on VLLM_PORT. No NGC key required —
# Chatterbox is open-weights (Resemble AI / Apache-2.0).
#
# CO-RESIDENCE: these share the GPU with the two LLM backends. The base fleet
# already barely co-fits two ~30B NVFP4 models on a GB10 — audio realistically
# wants a dedicated box or a single LLM. See docs/realtime-pipeline.md.

# Internal ports (compose network only; the gateway fronts them on VLLM_PORT).
CHATTERBOX_PORT=9000
PARAKEET_PORT=9002
REALTIME_PORT=8080

# Parakeet STT model (NeMo ASR).
PARAKEET_MODEL=nvidia/parakeet-tdt-0.6b-v2

# HuggingFace model cache (shared by Chatterbox and Parakeet on the host).
# Defaults to ~/.cache/huggingface.
HF_CACHE=

# TTS defaults. Chatterbox ships one built-in default voice.
# Leave DEFAULT_VOICE empty to use the default voice, or set it to an absolute
# path of a .wav reference clip to enable zero-shot voice cloning.
DEFAULT_VOICE=

# TTS_SPEED is accepted by the realtime bridge for API compatibility but is not
# forwarded to Chatterbox (the sidecar has no speed control).
TTS_SPEED=125

# TTS_CONCURRENCY: max parallel BATCH-lane TTS requests (POST
# /v1/audio/speech) — gates tts_client.py's asyncio.Semaphore for that lane
# only (see "TTS concurrency lanes" below). Clamped to >=1 in
# lobes/realtime/_settings.py: Semaphore(0) or a negative value blocks every
# batch TTS request forever, so a 0/negative value here is actively harmful,
# not merely a no-op — keep the deployed value sane instead of relying on
# that clamp to save you.
TTS_CONCURRENCY=1

# TTS concurrency lanes (issue #151 t7). tts_client.py gates every Chatterbox
# request behind an asyncio.Semaphore. Before this task there was ONE such
# gate, shared by the batch POST /v1/audio/speech route AND a live
# /v1/realtime session's own spoken replies — a voice reply could queue
# behind unrelated batch TTS work already in flight, and in a spoken turn
# that queueing IS dead air.
#
# CHOSEN FIX: two INDEPENDENT semaphore pools, not one raised shared number.
# Raising a shared ceiling only reduces how OFTEN batch traffic blocks a
# voice reply — it cannot guarantee a voice reply never waits behind a batch
# caller that fully saturates the pool (e.g. several concurrent batch
# requests). Splitting the pool is a structural guarantee; a bigger shared
# pool is only a probabilistic one.
#
# TTS_CONCURRENCY (above) now gates ONLY the batch lane and is UNCHANGED —
# the batch route stays byte-identical to before this task.
#
# TTS_VOICE_CONCURRENCY gates ONLY the voice lane. It defaults to 1 —
# matching TTS_CONCURRENCY's own historical default — deliberately, not 2+:
# concurrent /v1/realtime sessions are not yet validated (see the #149
# follow-up debt in docs/plans/), so this default claims only what is
# proven — lane ISOLATION from batch traffic — not untested multi-session
# throughput. Raise it if/when concurrent-session support is validated on
# your deployment.
TTS_VOICE_CONCURRENCY=1

# VAD / turn detection / AEC defaults for the /v1/realtime WS session (issue
# #149). Read by lobes/realtime/_settings.py; see docs/realtime-pipeline.md.

# VAD_THRESHOLD: Silero VAD speech-probability threshold (0.0-1.0) above which a frame counts as speech.
VAD_THRESHOLD=0.5

# VAD_SILENCE_MS: trailing silence (ms) required before an open speech turn is closed.
VAD_SILENCE_MS=600

# VAD_PREFIX_PADDING_MS: audio (ms) kept before the detected speech onset when a turn opens.
VAD_PREFIX_PADDING_MS=300

# VAD_MAX_TURN_MS: hard cap (ms) on one uninterrupted turn before it is force-committed.
VAD_MAX_TURN_MS=30000

# DEFAULT_TURN_DETECTION: turn_detection mode a session uses when it doesn't set one explicitly.
DEFAULT_TURN_DETECTION=server_vad

# DEFAULT_AEC_MODE: echo-cancellation mode; stays off (none) unless a session explicitly enables it.
DEFAULT_AEC_MODE=none

# Barge-in (issue #151 t8): the shipped-since-#149-but-never-passed knobs.
# Before this task neither key reached the realtime container's environment —
# both silently pinned to their in-code default (lobes/realtime/_settings.py)
# with no way for an operator to tune them (the #149 s4 lesson: a settings
# key the compose env never passes is a dead knob).

# BARGE_IN_WINDOW_MS: how long injected speech must be detected during a
# spoken reply before playback is cut and the interruption event fires.
# Mirrors VAD_SILENCE_MS's units (ms). A 0/near-0 value would treat ordinary
# short pauses in ambient background noise as a barge-in trigger on almost
# every reply, cutting playback before a listener can hear anything — 750 ms
# is the shipped default, chosen wider than VAD_SILENCE_MS's own 600 ms
# turn-close window so ordinary VAD boundary noise inside a reply does not
# double as an accidental interrupt.
BARGE_IN_WINDOW_MS=750

# BARGE_IN_MODEL: optional dedicated barge-in-detection model name/path. The
# in-tree floor machine ships WINDOW-ONLY barge-in (BARGE_IN_WINDOW_MS
# above); this knob is read and threaded through end to end but not yet
# consumed by any classifier — leave it empty unless/until a barge-in model
# is wired (tracked as a follow-up risk in the #151 plan: window-only ships
# first, a dedicated model is the recorded mitigation if the live run shows
# window-only insufficient).
BARGE_IN_MODEL=

# DEFAULT_SYSTEM_PROMPT (issue #151): the operator-set DEFAULT system prompt
# for every session's server-side reply generation — the OPERATOR half of
# "an operator-set default system prompt via env and a per-session override
# in the connect config" (a client's own system_prompt in the connect config
# always overrides this). Leave empty to use the built-in spoken-style
# default (lobes/realtime/_session.py's DEFAULT_SYSTEM_PROMPT — short spoken
# sentences, no markdown/lists/code/emoji). Setting this to a prompt that
# drops that spoken-style constraint is actively harmful, not merely
# suboptimal: Chatterbox reads the reply aloud VERBATIM, so a reply that
# reverts to the model's normal written register (markdown, bullet lists,
# code fences) comes back as spoken nonsense — literal asterisks and list
# markers — instead of a sentence a listener can follow.
DEFAULT_SYSTEM_PROMPT=

# The realtime bridge's LLM is the fleet gateway itself (reuses the warm
# models, no extra vLLM).
#
# VOICE-LANE DEFAULT (issue #151, spec c4/h4): a spoken turn wants the
# multimodal (Gemma 4 12B) lane, not cortex — measured ~1 s to a short reply
# vs. a thinking model spending that same budget on a reasoning trace nobody
# hears. Leaving OPENAI_MODEL empty here does NOT mean "no policy": the
# generate-turn call site (lobes/realtime/_turn.py, wired by app.py) is
# responsible for resolving an empty settings.openai_model to "multimodal"
# for the voice lane specifically — this settings/deployment layer stays
# policy-free on purpose (a falsy model omits the request key entirely, so
# any OTHER caller that bypasses this default still gets ordinary gateway
# default-routing, unaffected). Set OPENAI_MODEL here only to override the
# voice-lane default, e.g. OPENAI_MODEL=cortex for full reasoning at the
# cost of latency, or a specific model id.
OPENAI_API_KEY=EMPTY
OPENAI_MODEL=

# Gateway → audio backend. The realtime container serves /v1/audio/* and the
# /v1/realtime WebSocket session (#149, #151); the gateway path-routes audio
# here and tunnels the WS handshake through untouched.
AUDIO_URL=http://realtime:8080
