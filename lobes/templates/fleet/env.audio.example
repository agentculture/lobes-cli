
# === Audio overlay (lobes init --fleet --audio) ============================
# Appended to .env when you scaffold with --audio. Consumed by
# docker-compose.audio.yml: Chatterbox TTS + Parakeet STT + the realtime
# bridge, fronted by the same gateway on VLLM_PORT. No NGC key required —
# Chatterbox is open-weights (Resemble AI / Apache-2.0).
#
# CO-RESIDENCE: these share the GPU with the two LLM backends. The base fleet
# already barely co-fits two ~30B NVFP4 models on a GB10 — audio realistically
# wants a dedicated box or a single LLM. See docs/realtime-pipeline.md.

# Internal ports (compose network only; the gateway fronts them on VLLM_PORT).
CHATTERBOX_PORT=9000
PARAKEET_PORT=9002
REALTIME_PORT=8080

# Parakeet STT model (NeMo ASR).
PARAKEET_MODEL=nvidia/parakeet-tdt-0.6b-v2

# HuggingFace model cache (shared by Chatterbox and Parakeet on the host).
# Defaults to ~/.cache/huggingface.
HF_CACHE=

# TTS defaults. Chatterbox ships one built-in default voice.
# Leave DEFAULT_VOICE empty to use the default voice, or set it to an absolute
# path of a .wav reference clip to enable zero-shot voice cloning.
DEFAULT_VOICE=

# TTS_SPEED is accepted by the realtime bridge for API compatibility but is not
# forwarded to Chatterbox (the sidecar has no speed control).
TTS_SPEED=125

# The realtime bridge's LLM is the fleet gateway itself (reuses the warm models,
# no extra vLLM). Leave OPENAI_MODEL empty → the gateway default-routes.
OPENAI_API_KEY=EMPTY
OPENAI_MODEL=

# Gateway → audio backend. The realtime container serves /v1/audio/* (+ the
# /v1/realtime WS in a later release); the gateway path-routes audio here.
AUDIO_URL=http://realtime:8080
