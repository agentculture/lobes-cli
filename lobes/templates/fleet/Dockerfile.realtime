# lobes realtime bridge — the audio + speech front of the fleet.
#
# `lobes init --fleet --audio` scaffolds this next to docker-compose.audio.yml,
# which builds it as the `realtime` service. Mirrors Dockerfile.gateway: install
# lobes-cli from PyPI and run a packaged entrypoint — but with the [realtime]
# extra (fastapi, uvicorn, httpx, numpy, scipy, silero-vad, torch), which the
# base wheel and the gateway never pull.
#
# MODEL_GEAR_VERSION pins the image to the lobes-cli release that scaffolded the
# deployment (init --fleet writes the running version into .env). Required.
FROM python:3.12-slim
ARG MODEL_GEAR_VERSION
# Dev lane — same contract as Dockerfile.gateway: GATEWAY_PIP_EXTRA_INDEX_URL in
# .env names the index (e.g. TestPyPI) holding a .devN of MODEL_GEAR_VERSION.
# Two steps on purpose: the .devN wheel is fetched --no-deps from THAT index
# only, then the normal install sees it satisfied and resolves the [realtime]
# deps from real PyPI — a single extra-index would let TestPyPI name-squats
# (e.g. FASTAPI-1.0) outrank the real packages. Empty = no-op, release builds
# byte-identical.
ARG LOBES_DEV_INDEX_URL=
# One layer: install lobes-cli[realtime] (system-wide, as root) and create the
# unprivileged runtime user. The bridge binds :8080 internally and makes outbound
# HTTP calls to stt / tts / the gateway on the compose network.
RUN if [ -n "${LOBES_DEV_INDEX_URL}" ]; then \
        pip install --no-cache-dir --no-deps --index-url "${LOBES_DEV_INDEX_URL}" \
            "lobes-cli==${MODEL_GEAR_VERSION}"; \
    fi \
    && pip install --no-cache-dir "lobes-cli[realtime]==${MODEL_GEAR_VERSION}" \
    && useradd --create-home --uid 10002 realtime
USER realtime
EXPOSE 8080
ENTRYPOINT ["python", "-m", "lobes.realtime"]
