# Copy to .env (lobes init --fleet does this) and adjust. Consumed by the fleet
# docker-compose.yml: the always-warm Qwen generate primary, two tiny co-resident
# embedding + reranker gears, and a stdlib gateway that fronts them on one
# OpenAI-compatible port.
#
# The gateway routes by task family (generate / embed / score / rerank) — an
# unknown/missing `model` defaults to GATEWAY_DEFAULT_MODEL (the primary). There
# is one generate backend by default: the primary keeps its load-tested headroom
# (util 0.6, full 256K context, ~75 GiB) while the ~0.6B embed/rerank gears
# (util 0.06 each) co-reside in the GB10's 128 GB unified memory.
#
# TO ADD A WARM FALLBACK, define a vllm-fallback service in the compose, set
# FALLBACK_URL + FALLBACK_SERVED_NAME on the gateway, and drop both GPU_MEM_UTIL
# values so they sum well under 1.0. CO-RESIDENCE NEEDS HEADROOM: live-validated
# 2026-05-30, two ~30B NVFP4 models do NOT co-fit on a GB10 also running other
# services. See docs/gateway-fleet.md "Live validation findings".

# HuggingFace token. Required only for gated repos — accept the license first,
# then paste a read token. Injected into the vLLM backend(s), not the gateway.
# SECURITY: the primary serves with --trust-remote-code (custom modeling code) and
# this token is injected into that container. The default checkpoint is public —
# leave HF_TOKEN empty; for a gated repo use a minimal-scope read-only token.
HF_TOKEN=

# Host path for the HuggingFace weight cache (shared by any vLLM backend). Defaults
# to ~/.cache/huggingface (or /root/.cache/huggingface if $HOME is unset).
HF_CACHE=

# Host dir for durable, restart-surviving logs (issue #50). Each vLLM gear tees its
# stdout+stderr here as per-boot files ({primary,embed,rerank}-<boot>.log) via
# mg-logwrap, so a crash trace survives restart/recreate. Read with `lobes logs`.
# Default ./logs next to docker-compose.yml; set an absolute path to pin a disk.
MODEL_GEAR_LOG_DIR=

# Shared vLLM nightly image for the text gears (primary/embed/rerank) — pinned by
# digest so all three stay on ONE engine (0.23.1rc1.dev672; the same nightly the
# Gemma multimodal gear builds from). Set once here; a future digest bump is a
# one-line change instead of editing three services. See docs/vllm-nightly-migration.md.
VLLM_NIGHTLY_IMAGE=vllm/vllm-openai@sha256:7c5a10e9a8b3c8642f4d0463a41215176c0dd834b4f0967287c7e3e517cf1be9

# --- Primary backend (the gateway's default model) ------------------------
# The MTP speculative-decoding 27B (text-only): ~2.4x decode vs the archived
# baseline, tool calling + reasoning verified 2026-05-31. The MTP serve flags
# (--speculative-config / --trust-remote-code / --language-model-only /
# --tokenizer override) are baked into the fleet compose's vllm-primary service.
PRIMARY_MODEL=sakamakismile/Qwen3.6-27B-Text-NVFP4-MTP
PRIMARY_SERVED_NAME=sakamakismile/Qwen3.6-27B-Text-NVFP4-MTP
PRIMARY_MAX_MODEL_LEN=131072                 # the primary now serves its full 128K native context — the 27B KV cache is util-bound, not context-bound, so 64K->128K trades concurrency at the same memory footprint. See GPU budget below.
PRIMARY_GPU_MEM_UTIL=0.30                    # live-validated 2026-07-03 (#81 t12): cortex@128K at util 0.30 = 3.58x concurrency (18.02 GiB / 468,886-token KV), healthy co-resident with senses@32K. See GPU budget below.
PRIMARY_MAX_NUM_SEQS=2                        # MTP cap — 4 OOMs at n=3/high context (see docs/qwen3.6-27b-text-nvfp4-mtp.md)
PRIMARY_TOOL_CALL_PARSER=qwen3_coder         # Qwen3.6 emits the Qwen3-Coder XML function format
PRIMARY_QUANTIZATION=modelopt                # MTP re-export uses plain `modelopt` (native SM120 NVFP4 path; resolves to modelopt_fp4)
# fp8 KV needs calibrated k_scale/v_scale in the checkpoint; this NVFP4 re-export
# ships none (kv_cache_quant_algo: null), so fp8 trips `assert layer.k_scale > 0.0`
# on some vLLM nightlies/hardware. Shipped default STAYS fp8 (GB10 behavior
# unchanged). Thor (sm_110) sets: PRIMARY_KV_CACHE_DTYPE=auto (see #109).
PRIMARY_KV_CACHE_DTYPE=fp8

# --- Fallback backend (optional; none by default) -------------------------
# The fleet ships one generate backend. To add a warm generate fallback, define a vllm-fallback
# service in the compose and set FALLBACK_URL + FALLBACK_SERVED_NAME below (the
# gateway adds a second backend only when those are present), then lower both
# GPU_MEM_UTIL values. The archived dense Mistral-Small-3.2-24B (NVFP4) fallback
# config lives in git history and docs/mistral-small-3.2-24b-nvfp4.md; Mistral
# remains a selectable catalog candidate (`lobes overview --list`).
# FALLBACK_URL=http://vllm-fallback:8000
# FALLBACK_SERVED_NAME=

# --- Embedding + reranker gears (co-resident, tiny footprint) --------------
# Two 0.6B gears served alongside the primary. Each gets util 0.06 (~7 GiB
# budget apiece; 0.025 OOMs the pooling cache blocks — load-tested 2026-06-19);
# the primary + both gears sum well under 1.0 on the 128 GB GB10. Context is
# capped at 8192 tokens to keep KV cache tiny — short-context embed/rerank
# workloads, not generation.
#
# Embedding: Qwen3-Embedding-0.6B — 1024-dim Matryoshka embeddings (dims:
# 32/64/128/256/512/768/1024 selectable via the API truncation parameter).
# The is_matryoshka hf-override is baked into the compose service command.
EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBED_SERVED_NAME=Qwen/Qwen3-Embedding-0.6B
EMBED_MAX_MODEL_LEN=8192
# 0.06 load-tested 2026-06-19; 0.025 fails with "No available memory for the cache
# blocks" (vLLM's pooling runner still reserves a cache-block budget).
EMBED_GPU_MEM_UTIL=0.06
# Internal URL the gateway uses to reach the embedding backend.
EMBED_URL=http://vllm-embed:8000
# Attention backend for the pooling runner. "auto" (the shipped default) is
# byte-equivalent to omitting --attention-config entirely — vLLM's
# AttentionConfig.backend treats the string "auto" as its own automatic-
# selection sentinel (vllm/config/attention.py). Thor (sm_110) sets:
# EMBED_ATTENTION_BACKEND=TRITON_ATTN — the auto-picked FLASH_ATTN pooling
# path hangs the forward pass there (VLLM_ATTENTION_BACKEND is gone on this
# nightly; AttentionConfig is the only honoured knob). See #109/#105.
EMBED_ATTENTION_BACKEND=auto

# Reranker: Qwen3-Reranker-0.6B — sequence classification reranker.
# The Qwen3ForSequenceClassification hf-override + classifier_from_token
# ["no","yes"] are baked into the compose service command (required for the
# reranker head; vLLM --runner pooling --convert classify picks up the
# classification logits).
RERANK_MODEL=Qwen/Qwen3-Reranker-0.6B
RERANK_SERVED_NAME=Qwen/Qwen3-Reranker-0.6B
RERANK_MAX_MODEL_LEN=8192
RERANK_GPU_MEM_UTIL=0.06
# Internal URL the gateway uses to reach the reranker backend.
RERANK_URL=http://vllm-rerank:8000
# Attention backend for the pooling runner — same "auto" sentinel/rationale as
# EMBED_ATTENTION_BACKEND above. Thor (sm_110) sets:
# RERANK_ATTENTION_BACKEND=TRITON_ATTN — same FLASH_ATTN pooling bug as
# vllm-embed, surfacing here as NaN relevance scores instead of a hang. See
# #109/#105.
RERANK_ATTENTION_BACKEND=auto
# Whole CLI token, not a bool — vLLM's `enforce_eager: bool` field gets
# argparse.BooleanOptionalAction, so both --enforce-eager and
# --no-enforce-eager are always-valid tokens (never a conditionally-omitted
# flag). The shipped default --no-enforce-eager is an explicit no-op
# (ModelConfig.enforce_eager already defaults to False, i.e. CUDA graphs on)
# — byte-equivalent effective behavior to today's flagless render. Thor
# (sm_110) sets: RERANK_ENFORCE_EAGER=--enforce-eager — the classify path
# faults under CUDA graphs (cudaErrorLaunchFailure kills the engine
# mid-request). See #109/#106.
RERANK_ENFORCE_EAGER=--no-enforce-eager

# --- Opt-in minor generate backend (4B, bf16) ----------------------------
# Activate with: docker compose --profile minor up -d
# OR add "minor" to COMPOSE_PROFILES in .env.
# When active, set MINOR_BASE_URL so the gateway routes minor-model requests here.
# MINOR_MODEL=Qwen/Qwen3.5-4B
# MINOR_SERVED_NAME=Qwen/Qwen3.5-4B
# MINOR_BASE_URL=http://vllm-minor:8000
# VLLM_MINOR_MAX_MODEL_LEN=32768
# VLLM_MINOR_GPU_MEM_UTIL=0.10

# --- Opt-in middle generate backend (14B NVFP4, legacy candidate) ----------
# LEGACY: the 14B "middle" is no longer the "normal" tier — that role is now
# filled by the default-on vllm-multimodal (Gemma 4 12B) gear. This entry is
# kept for operators who explicitly want the Qwen 14B text-only model.
# Activate with: docker compose --profile middle up -d
# OR add "middle" to COMPOSE_PROFILES in .env.
# When active, set MIDDLE_BASE_URL so the gateway routes middle-model requests here.
MIDDLE_MODEL=nvidia/Qwen3-14B-NVFP4
MIDDLE_SERVED_NAME=nvidia/Qwen3-14B-NVFP4
# MIDDLE_BASE_URL=http://vllm-middle:8000    # uncomment to activate gateway routing
MIDDLE_MAX_MODEL_LEN=32768
MIDDLE_GPU_MEM_UTIL=0.12

# --- Multimodal generate backend (Gemma 4 12B, NVFP4, default-on) ----------
# The fleet's "multimodal" generate gear: Gemma 4 12B unified text+image+audio.
# Always started alongside the primary (no --profile required). Vision + audio
# are active (no --language-model-only). NVFP4. Native MTP speculative decoding
# is ON BY DEFAULT (docs/vllm-nightly-migration.md §7): the NVFP4 BASE it-model
# (coolthor/gemma-4-12B-it-NVFP4A16), not the coder fine-tune — measured 28.6
# tok/s at 57.9% draft acceptance, the fastest Gemma config on this hardware. The
# coder fine-tune is KEPT as the opt-in `vllm-multimodal-coder` service below
# (coding-strong, but its MTP acceptance is only 30.8% — not worth defaulting).
# GPU budget: util 0.14 (~18 GiB, 32K context) alongside the 27B primary (util
# 0.30, 128K context, ~38 GiB) — util 0.14 is PROVISIONAL, to be validated live
# on the GB10 (plan task t12); see docs/vllm-nightly-migration.md §8.
# TODO(risk r5): measure real multimodal util (vision+audio KV) on the Spark in t7.
#
# MULTIMODAL_IMAGE — controls the OCI image for the vllm-multimodal service.
# Gemma 4's gemma4_unified arch needs vLLM's native Gemma4UnifiedForConditionalGeneration
# class (only in vLLM nightly >= 0.23.1rc1), so vllm-multimodal uses a custom
# Dockerfile (Dockerfile.vllm-gemma4) built FROM the official vllm/vllm-openai
# nightly image (pinned by digest) + the vllm[audio] extra.  Two usage modes:
#
#   Unset (default local build):
#     `lobes fleet up --apply` runs `docker compose up -d --build`, which builds
#     Dockerfile.vllm-gemma4 and tags the result as lobes/vllm-gemma4:local.
#     No value needed here — the build: block in docker-compose.yml handles it.
#
#   Set to a registry tag (pre-built image):
#     MULTIMODAL_IMAGE=ghcr.io/agentculture/vllm-gemma4:latest
#     Then pull it and run WITHOUT --build (a --build would rebuild the local
#     Dockerfile and shadow the pulled tag):
#       docker compose pull vllm-multimodal
#       docker compose up -d vllm-multimodal   # no --build; uses the pulled tag
#     `lobes fleet up` forces --build, so use plain docker compose for a registry
#     tag (or a future `lobes fleet up --no-build`).
#     A local registry tag (e.g. lobes/vllm-gemma4:custom) works the same way.
#
# MULTIMODAL_IMAGE=ghcr.io/agentculture/vllm-gemma4:latest   # example registry tag
MULTIMODAL_MODEL=coolthor/gemma-4-12B-it-NVFP4A16
MULTIMODAL_SERVED_NAME=coolthor/gemma-4-12B-it-NVFP4A16
MULTIMODAL_BASE_URL=http://vllm-multimodal:8000
# Trimmed to 32K (from 128K) to free KV headroom for the 27B primary to serve
# its full 128K native context — the always-on duo's context rebalance. Superseded
# the earlier 131072/util-0.22 pairing (#71). See docs/vllm-nightly-migration.md §8.
MULTIMODAL_MAX_MODEL_LEN=32768
# LIVE-VALIDATED on the GB10 2026-07-03 (#81 t12): senses@32K at util 0.14 =
# 8.87 GiB available KV (184,084 tokens) = 5.62x concurrency — healthy, with margin.
# DO NOT go lower: Gemma-12B weights+CUDA-graph are ~13.4 GiB (~util 0.105 floor),
# so 0.10 would OOM before any KV cache.
MULTIMODAL_GPU_MEM_UTIL=0.14
# vLLM 0.23 over-estimates cudagraph memory for this gear (12.74 GiB estimated vs
# 0.46 GiB actual, #71), starving the KV cache so a naive util fails with "No
# available memory for the cache blocks". Disabling the estimate maps the util
# knob back to true usage (~18 GiB actual ≈ 0.14 of the 128 GB GB10, §8). Set to
# 1 to re-enable.
MULTIMODAL_CUDAGRAPH_ESTIMATE=0
# compressed-tensors (nvfp4-pack-quantized) — the checkpoint's own quant_method.
# NOT modelopt_fp4 (that fails with a quant-method mismatch). Verified live (#71).
MULTIMODAL_QUANTIZATION=compressed-tensors
# Attention backend. Gemma 4 interleaves sliding (head 256) and full-attention
# (head 512) layers; TRITON_ATTN handles the heterogeneous sizes. The native
# gemma4_unified class auto-forces it; set explicitly too (matches the vLLM recipe).
MULTIMODAL_ATTENTION_BACKEND=TRITON_ATTN
# Native MTP speculative decoding is baked into the vllm-multimodal command in
# docker-compose.yml (a literal --speculative-config flag, matching
# lobes.catalog.SUPPORTED_MODELS' coolthor entry — not env-parameterized, same as
# the 27B primary's --speculative-config). 57.9% draft acceptance, ~1.45x decode
# (docs/vllm-nightly-migration.md §7). To disable spec-decode entirely, remove that
# line from the compose command by hand. The DeepSeek DSpark draft
# (deepseek-ai/dspark_gemma4_12b_block7) was investigated and found INVALID on
# vLLM 0.23 — its custom Gemma4DSparkModel architecture is not in the supported
# speculative-draft set (§6) — do not wire it.

# --- Opt-in coder generate backend (Gemma 4 12B coder fine-tune) -----------
# KEPT (cite-don't-delete), DEMOTED from the default "multimodal" gear (§7):
# coding-strong, but native MTP only reaches 30.8% draft acceptance on this
# fine-tune (a marginal ~6% decode win) — not worth wiring/defaulting.
# Activate with: docker compose --profile multimodal-coder up -d
# OR add "multimodal-coder" to COMPOSE_PROFILES in .env.
# When active, set MULTIMODAL_CODER_BASE_URL so the gateway routes the
# "multimodal-coder" alias (and the coder's served id) here.
MULTIMODAL_CODER_MODEL=sakamakismile/gemma-4-12B-coder-fable5-composer2.5-MTP-NVFP4
MULTIMODAL_CODER_SERVED_NAME=sakamakismile/gemma-4-12B-coder-fable5-composer2.5-MTP-NVFP4
# MULTIMODAL_CODER_BASE_URL=http://vllm-multimodal-coder:8000    # uncomment to activate gateway routing
MULTIMODAL_CODER_MAX_MODEL_LEN=8192
MULTIMODAL_CODER_GPU_MEM_UTIL=0.12
MULTIMODAL_CODER_QUANTIZATION=compressed-tensors
MULTIMODAL_CODER_ATTENTION_BACKEND=TRITON_ATTN
MULTIMODAL_CODER_CUDAGRAPH_ESTIMATE=0
# No speculative decoding: native MTP measured only 30.8% draft acceptance on this
# coder fine-tune (§6/§7) — not worth wiring.

# GPU-mem-util co-residency budget — the "always-on duo" defaults. The cortex/senses
# (128K/32K) rebalance was live-validated co-resident on the GB10 2026-07-03 (#81 t12):
# cortex@128K/0.30 = 3.58x concurrency (18.02 GiB KV), senses@32K/0.14 = 5.62x (8.87 GiB
# KV), both healthy. (Raise carefully — vLLM fills its util budget with KV cache
# regardless of --max-model-len, so weights + KV must both fit.)
#   Default fleet: cortex 0.30 (128K) + senses 0.14 (32K) + embed 0.06 +
#     rerank 0.06 = 0.56. cortex serves its full 128K context; the always-on Gemma
#     senses gear is trimmed to 32K to free the KV headroom.
#   With opt-in minor (4B):
#     primary 0.30 + multimodal 0.14 + minor 0.10 + embed 0.06 + rerank 0.06 = 0.66
#   With opt-in middle (14B legacy): add 0.12 to any of the above.
#   With opt-in multimodal-coder (12B, alongside the default multimodal base gear):
#     add 0.12 to any of the above.
# Without multimodal (primary + embed + rerank only):
#   primary 0.30 + embed 0.06 + rerank 0.06 = 0.42  (raise primary toward 0.6+ if desired)

# --- Gateway (single front OpenAI endpoint) -------------------------------
# Host port acp/culture.yaml expects → mapped to the gateway. The primary backend
# is reachable only on the internal compose network (vllm-primary:8000).
VLLM_PORT=8000
# GATEWAY_PUBLIC_URL — OPTIONAL override for a tunnel / Host-rewriting reverse
# proxy ONLY (e.g. a cloudflared tunnel URL like https://foo.example). Set it
# only when clients dial a different origin than the one they connect to.
# Leave it EMPTY (the default) for a normal published host port: the gateway
# then echoes the origin the client actually dialed (its request Host header)
# in GET /capabilities, so the advertised endpoint is reachable as-is. Do NOT
# set it to a localhost/published-port URL — a set value outranks the Host
# header and would advertise loopback to every remote client (issue #92 / #96).
# GATEWAY_PUBLIC_URL=
# Where a request with a missing/unknown `model` routes. EMPTY (the default)
# means "follow the primary gear's served name" (PRIMARY_SERVED_NAME), so the
# default stays correct when a machine profile swaps the cortex model (e.g. the
# conservative `base` profile serves a 4B — a hardcoded 27B here would route
# no-model requests to a name nothing serves). Set it only to pin a different
# explicit default.
GATEWAY_DEFAULT_MODEL=
# Extra name -> served-name routes, comma-separated (e.g.
# 27b=sakamakismile/Qwen3.6-27B-Text-NVFP4-MTP).
GATEWAY_ALIASES=
# Short connect timeout (failover-relevant) vs long read timeout (a reasoning
# model's first token is slow — too tight would falsely trip failover).
GATEWAY_CONNECT_TIMEOUT=5
GATEWAY_READ_TIMEOUT=600

# Pressure policy (issue #68): under host memory pressure the gateway degrades
# `main`-tier requests to `minor`. Tune the trigger thresholds per box (defaults
# match the code). Raise LOBES_IOWAIT_DEGRADED_THRESHOLD to 100 to effectively
# DISABLE iowait-based degradation on boxes where /proc/pressure/io reports a
# phantom high value with an idle disk (e.g. the DGX Spark GB10 — dgx-spark-cli#22);
# the swap guard then remains as the real memory-pressure protection.
LOBES_SWAP_DEGRADED_THRESHOLD=75
LOBES_IOWAIT_DEGRADED_THRESHOLD=50

# Pins the gateway image to this lobes-cli release (lobes init --fleet fills in
# the running version). Required — dev/from-source boxes set a TestPyPI .devN.
MODEL_GEAR_VERSION=

# GATEWAY_PIP_EXTRA_INDEX_URL — OPTIONAL dev lane paired with a .devN
# MODEL_GEAR_VERSION: an extra pip index (e.g. https://test.pypi.org/simple/)
# the gateway image build may resolve that version from, so an unreleased
# branch can be validated live with zero hand-edits. Leave unset on releases.
# GATEWAY_PIP_EXTRA_INDEX_URL=

# Coherence mirrors so the read-only verbs (status / whoami / doctor) — which read
# the single-model VLLM_* keys — stay sensible on a fleet deployment. Keep equal
# to PRIMARY_* (the gateway's default).
VLLM_MODEL=sakamakismile/Qwen3.6-27B-Text-NVFP4-MTP
VLLM_SERVED_NAME=sakamakismile/Qwen3.6-27B-Text-NVFP4-MTP
VLLM_TOOL_CALL_PARSER=qwen3_coder
