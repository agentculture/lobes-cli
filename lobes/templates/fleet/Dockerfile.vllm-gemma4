# lobes vLLM-Gemma4 — custom vLLM image that registers the gemma4_unified arch.
#
# The NGC vLLM 26.05.post1 base ships vLLM 0.21.x but a Transformers version
# that does NOT yet register gemma4_unified in AutoConfig.  This Dockerfile
# overlays a newer (or from-source) Transformers build so the Gemma 4 12B
# multimodal gear loads without "unknown architecture" errors.
#
# TRANSFORMERS_REF — the Transformers ref to install. Pinned to a specific commit
# for reproducible rebuilds. This SHA was validated on the DGX Spark (t3,
# 2026-06-30): it registers gemma4_unified in AutoConfig AND leaves vLLM 0.21.0
# importing/serving. It resolves to transformers 5.13.0.dev0. Bump deliberately
# (and re-validate) rather than floating to main HEAD. Override at build time with
# --build-arg TRANSFORMERS_REF=... to test a newer ref.
#
# Full checkpoint download + live serving is NOT performed at build time (that
# would require network access to HuggingFace Hub and GPU resources during CI).
# The build-stage verification below is network-free; live serving is task t4.
FROM nvcr.io/nvidia/vllm:26.05.post1-py3

ARG TRANSFORMERS_REF=git+https://github.com/huggingface/transformers.git@181beb3ba4c47098ed8cbc97ee250d1d45ae0107

# ---------------------------------------------------------------------------
# Overlay the Transformers build that registers gemma4_unified.
#
# uv ships in the NGC 26.05 base image (0.11.x), so no bootstrap is needed.
# `uv pip install --system` writes into the container's system site-packages
# (/usr), which is where vLLM's import paths resolve. --break-system-packages is
# required: that interpreter carries a PEP 668 EXTERNALLY-MANAGED marker — the
# base sets PIP_BREAK_SYSTEM_PACKAGES=1 for pip, but uv needs the explicit flag.
# (The base also sets PIP_CONSTRAINT=/etc/pip/constraint.txt, which uv ignores —
# intentional here: we WANT to override the base's pinned Transformers.)
# ---------------------------------------------------------------------------
RUN uv pip install --system --break-system-packages --no-cache-dir "${TRANSFORMERS_REF}"

# ---------------------------------------------------------------------------
# Build-stage verification (network-free).
#
# Asserts that the installed Transformers version registers gemma4_unified in
# AutoConfig's CONFIG_MAPPING and that vLLM's ModelRegistry exposes at least
# one Gemma4 architecture.  This proves the overlay worked without requiring
# the actual checkpoint to be downloaded.
#
# Note: a full AutoConfig.from_pretrained(<checkpoint>) needs network at build
# time and is fragile in CI — we deliberately avoid it here.  The checkpoint
# load + end-to-end serve path is validated live in task t3 (risk r1).
# ---------------------------------------------------------------------------
# Single logical line: each statement ends with `;` and the physical line is
# continued with a trailing backslash. A multi-line `python3 -c "..."` WITHOUT
# backslash continuations makes Docker parse each body line as its own (unknown)
# instruction — see tests/test_gemma4_dockerfile.py for the lint that guards this.
RUN python3 -c "import transformers; import vllm; \
    assert 'gemma4_unified' in transformers.models.auto.configuration_auto.CONFIG_MAPPING, 'gemma4_unified not found in CONFIG_MAPPING — Transformers ref too old or wrong'; \
    supported = vllm.ModelRegistry.get_supported_archs(); \
    gemma4_archs = [a for a in supported if 'Gemma4' in a]; \
    assert gemma4_archs, 'No Gemma4 arch found in vllm.ModelRegistry.get_supported_archs()'; \
    print('OK — gemma4_unified registered; import vllm OK; Gemma4 arch in ModelRegistry:', gemma4_archs)"
