# Cloudflare Tunnel config for `lobes tunnel` — copy to `.cf-tunnel.env` in this
# deployment dir and fill in your values:
#
#   cp cf-tunnel.env.example .cf-tunnel.env   # then edit; .cf-tunnel.env is gitignored
#
# This file holds NO secrets (placeholders only) and is safe to commit; the live
# `.cf-tunnel.env` holds your hostname + run-token and must NEVER be committed.
#
# Provision the Cloudflare side ONCE (tunnel + ingress + DNS, run-token sealed in
# shushu) with the sibling `cultureflare` tool, in its tunnel-only mode:
#
#   cultureflare remote-login setup \
#     --hostname <owner-host> \
#     --service http://127.0.0.1:8000 \
#     --no-access --shushu --apply
#
# Then: `lobes serve --apply` (with CULTURE_VLLM_API_KEY set in .env) + `lobes tunnel --apply`.

# Public hostname clients address the model by (owner-chosen). Kept out of the
# repo — `lobes tunnel` also accepts it via `--hostname` or $CULTURE_VLLM_PUBLIC_HOSTNAME.
CULTURE_VLLM_PUBLIC_HOSTNAME=<choose-by-owner>

# Token source — PREFERRED: the name of the shushu-sealed cloudflared run-token
# (sealed by `cultureflare ... --shushu`). `lobes tunnel` runs:
#   shushu run --inject TOKEN=<name> -- cloudflared tunnel run --token "$TOKEN"
CULTURE_CF_TUNNEL_TOKEN_SHUSHU=<shushu-secret-name>

# …or a plaintext run-token fallback (less safe — avoid; never commit a real one).
# If set and the shushu name is empty, `lobes tunnel` runs:
#   cloudflared tunnel run --token <token>
# CULTURE_CF_TUNNEL_TOKEN=
