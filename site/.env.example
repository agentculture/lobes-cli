# The local credential-injecting proxy's two knobs (issue #151 t13).
#
# Copy to `.env` and edit. `.env` is git-ignored — see site/.gitignore. The
# key must never be committed, and it never reaches the browser: this file is
# read by the Astro dev server process only, to build server-side proxy
# options (site/astro.config.mjs -> site/proxy/gateway-proxy.mjs).
#
# Neither name carries the `PUBLIC_` prefix (Astro's client-exposed
# namespace) or the `VITE_` prefix (Vite's). That is deliberate: both
# toolchains inline prefix-matching variables into the client bundle, so a
# key named with either prefix would be shipped to the browser by the build
# itself. Do not rename these.

# Where the proxy forwards. Default when unset: http://127.0.0.1:8000
#
# Keep this a LOCALHOST address. The documented flow reaches an off-box fleet
# through `ssh -L 8000:localhost:8000 <box>`, which is what makes the page's
# own origin a secure context — and getUserMedia gives a page NO microphone
# at all outside one. See site/README.md.
LOBES_GATEWAY_URL=http://127.0.0.1:8000

# The gateway's inbound bearer credential — a copy of the GATEWAY_API_KEY set
# in the fleet's .env on the box running the gateway.
#
# OPTIONAL. The gateway's inbound gate is opt-in: with GATEWAY_API_KEY unset
# there, the gate returns before the Authorization header is even read, and
# the proxy correctly attaches nothing. Leave this unset for such a fleet;
# setting a key it does not want is harmless but pointless.
LOBES_GATEWAY_API_KEY=
