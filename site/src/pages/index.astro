---
// The lobes realtime test harness — issue #151 t10.
//
// This page is the SHELL wave-2 attaches islands to. It deliberately does
// not implement mic capture, event rendering, or connection/auth — those
// are t11, t12, t13 respectively (see docs/plans/2026-07-21-realtime-
// voice-to-voice-astro-test-site-151.md). Each mount point below is a
// plain, styled <section> with a clearly commented anchor: a stable `id`
// plus a `data-mount` attribute a wave-2 island can select on
// (`document.querySelector('[data-mount="mic"]')`) without any
// restructuring of this layout.
//
// Client JS wave-2 adds should be regular Astro-bundled <script> modules
// (or a component's own <script> block), NOT `is:inline` — the honesty
// condition in the spec is explicit that the live WS island is "new
// client JS bundled by Astro, not is:inline". is:inline is reserved on
// this page for the two tiny, framework-free progressive-enhancement
// snippets in Layout.astro (the html.js flag and the [data-reveal]
// IntersectionObserver), which predate any island and stay that way.
import Layout from "../layouts/Layout.astro";
import SignalMesh from "../components/SignalMesh.astro";
import ConnectionPanel from "../components/ConnectionPanel.astro";
import MicIsland from "../components/MicIsland.astro";
import EventStream from "../components/EventStream.astro";
---

<Layout
  title="lobes realtime test harness"
  description="Local-only browser harness for driving the lobes /v1/realtime WebSocket surface: mic in, live event stream, audio out."
>
  <section class="section hero">
    <div class="container hero-grid">
      <div data-reveal>
        <span class="eyebrow">/v1/realtime — local only</span>
        <h1>Hear the mesh think.</h1>
        <p class="lede muted">
          A spoken turn goes out over one WebSocket and a spoken reply
          comes back on the same connection. This page exists so you can
          experience that exchange in a browser — watch VAD boundaries,
          transcripts, and interruptions scroll by — instead of inferring
          it from terminal prints.
        </p>
      </div>
      <div class="hero-signal" data-reveal style="--reveal-delay: 0.1s">
        <SignalMesh />
      </div>
    </div>
  </section>

  <!--
    ============================================================
    MOUNT POINT: t13 — connection / auth controls
    Fed by the local WebSocket proxy (Vite dev-server server.proxy, or its
    standalone fallback) that injects the Authorization bearer server-side.
    The browser must never hold or display the gateway API key here.
    ============================================================
  -->
  <section class="section" id="connection" aria-labelledby="connection-heading" data-reveal>
    <div class="container">
      <h2 id="connection-heading">Connection</h2>
      <p class="muted">
        Connect through the local proxy — the key lives only in the proxy
        process, never in this page.
      </p>
      <div class="mount card" id="connection-mount" data-mount="connection">
        <ConnectionPanel />
      </div>
    </div>
  </section>

  <!--
    ============================================================
    MOUNT POINT: t11 — mic capture + audio playback
    getUserMedia({ echoCancellation: true }) + AudioWorklet capture to
    24 kHz PCM16 base64 append events; a delta player for audio-out that
    stops local playback on the interruption event. Mic + playback arm
    ONLY from a start-control user gesture (AudioContext starts suspended);
    NotAllowedError/NotFoundError are distinct states, not silence.
    ============================================================
  -->
  <section class="section" id="mic" aria-labelledby="mic-heading" data-reveal>
    <div class="container">
      <h2 id="mic-heading">Mic &amp; playback</h2>
      <p class="muted">
        Arms together from one start gesture. Speaking during a reply
        interrupts it — echo cancellation only, no mic muting.
      </p>
      <div class="mount card" id="mic-mount" data-mount="mic">
        <MicIsland />
      </div>
    </div>
  </section>

  <!--
    ============================================================
    MOUNT POINT: t12 — live event-stream log
    Renders every /v1/realtime event type with timestamps, each named
    error code visually distinct from silence and from disconnect, and VAD
    boundary at_ms timing visible for knob tuning.
    ============================================================
  -->
  <section class="section" id="events" aria-labelledby="events-heading" data-reveal>
    <div class="container">
      <h2 id="events-heading">Event stream</h2>
      <p class="muted">
        Every session event, in order, with timing — the surface this site
        exists to make visible.
      </p>
      <div class="mount card" id="events-mount" data-mount="events">
        <EventStream />
      </div>
    </div>
  </section>
</Layout>

<script>
  // The island bridge (coordinator wiring, issue #151).
  //
  // t11, t12 and t13 were built in parallel, blind to each other, and each
  // named its own DOM seam. Their contracts are compatible in substance and
  // incompatible in spelling, so this is the one place that translates —
  // rather than editing three merged, independently-tested islands to agree
  // after the fact. Each island keeps the API its own tests pin.
  //
  //   t13 (transport, owns the socket)
  //     publishes  document "lobes:realtime-ready" -> { connection }
  //                window.lobesRealtime
  //     emits      document "lobes:realtime"       -> ConnectionNotice
  //                  { kind: "state", state, url, detail }
  //                  { kind: "event", event, raw }
  //                  { kind: "malformed" | "binary", ... }
  //     accepts    connection.sendEvent(event)
  //
  //   t11 (mic + playback)
  //     emits      document "lobes:client-event"   -> an append event to send
  //     consumes   document "lobes:server-event"   -> one parsed server event
  //     also       window.lobesMic.notifyDisconnected(reason)
  //
  //   t12 (event log)
  //     consumes   window "lobes:realtime-event"   -> one parsed server event
  //                window "lobes:connection-state" -> { state, detail }
  //
  // Sample rate needs no bridging: t13's panel owns the connect URL, and t11
  // adopts whatever `session.created` echoes back — the server's echo is the
  // authority, so the two converge without this file arbitrating.
  import type { ConnectionState } from "../scripts/realtime-connection";

  // t13 has five transport states; t12 renders four. "closing" folds into
  // "disconnected" (the socket is going away and the following "disconnected"
  // notice confirms it) and "failed" is the only one that reads as an error.
  // t13's own `detail` string rides along, so the nuance the fold drops is
  // still shown to the operator rather than lost.
  const STATE_TO_LOG: Record<ConnectionState, string> = {
    disconnected: "disconnected",
    connecting: "connecting",
    open: "connected",
    closing: "disconnected",
    failed: "error",
  };

  function bridge(connection: { sendEvent(event: Record<string, unknown>): boolean }) {
    // t11 -> t13: outbound audio.
    document.addEventListener("lobes:client-event", (evt) => {
      const detail = (evt as CustomEvent).detail;
      if (detail) connection.sendEvent(detail);
    });
  }

  // t13 -> t11 + t12: inbound events and transport state. Registered
  // immediately (not inside bridge()) so a notice that arrives before the
  // ready event — a connection opened from a restored form state, say — is
  // still relayed rather than dropped.
  document.addEventListener("lobes:realtime", (evt) => {
    const notice = (evt as CustomEvent).detail;
    if (!notice) return;

    if (notice.kind === "event") {
      document.dispatchEvent(
        new CustomEvent("lobes:server-event", { detail: notice.event }),
      );
      window.dispatchEvent(
        new CustomEvent("lobes:realtime-event", { detail: notice.event }),
      );
      return;
    }

    if (notice.kind === "state") {
      const state = STATE_TO_LOG[notice.state as ConnectionState] ?? "disconnected";
      window.dispatchEvent(
        new CustomEvent("lobes:connection-state", {
          detail: { state, detail: notice.detail },
        }),
      );
      // Tell the mic island the floor is gone, so it stops playback and
      // releases the device instead of waiting on a reply that cannot arrive.
      if (notice.state === "disconnected" || notice.state === "failed") {
        (window as { lobesMic?: { notifyDisconnected(reason: string): void } })
          .lobesMic?.notifyDisconnected(notice.detail ?? notice.state);
      }
    }
  });

  // The connection may publish before or after this module runs; handle both.
  const existing = (window as { lobesRealtime?: Parameters<typeof bridge>[0] })
    .lobesRealtime;
  if (existing) {
    bridge(existing);
  } else {
    document.addEventListener(
      "lobes:realtime-ready",
      (evt) => bridge((evt as CustomEvent).detail.connection),
      { once: true },
    );
  }
</script>

<style>
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 2rem 3rem;
  }

  .hero-signal {
    display: flex;
    justify-content: center;
  }

  .mount {
    margin-top: 1.5rem;
    min-height: 6rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 42rem) {
    .hero-grid {
      grid-template-columns: minmax(0, 1fr);
    }

    .hero-signal {
      order: -1;
    }
  }
</style>
