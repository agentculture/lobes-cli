# model-gear STT — NVIDIA Parakeet TDT 0.6B as an OpenAI-shaped ASR server.
#
# Vendored from the qwen3-tts sibling (cite-don't-import) so the build context is
# self-contained in the deployment dir (no external path). `model init --fleet
# --audio` writes this + listen_server.py; docker-compose.audio.yml builds it as
# the `stt` service. Serves POST /v1/audio/transcriptions (already OpenAI-shaped)
# and GET /v1/health/ready on PARAKEET_PORT (default 9002).
FROM scitrera/dgx-spark-vllm:0.16.0-t4

# System deps for audio
RUN apt-get update && apt-get install -y --no-install-recommends \
        ffmpeg alsa-utils \
    && rm -rf /var/lib/apt/lists/*

# Install NeMo ASR + Parakeet dependencies
RUN pip install --no-cache-dir \
    "nemo_toolkit[asr]" soundfile scipy

# Pre-download the model
RUN python3 -c "import nemo.collections.asr as nemo_asr; nemo_asr.models.ASRModel.from_pretrained('nvidia/parakeet-tdt-0.6b-v2')"

WORKDIR /app
# _readiness.py is a vendored copy of model_gear/realtime/_readiness.py (stdlib
# only, no wheel needed).  Copied here so listen_server.py can import it as a
# top-level module without requiring the model_gear wheel to be installed.
COPY _readiness.py /app/_readiness.py
COPY listen_server.py /app/listen_server.py

EXPOSE 9002

CMD ["python3", "/app/listen_server.py"]
