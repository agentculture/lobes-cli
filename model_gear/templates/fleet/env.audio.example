
# === Audio overlay (model init --fleet --audio) ============================
# Appended to .env when you scaffold with --audio. Consumed by
# docker-compose.audio.yml: Magpie TTS (NIM) + Parakeet STT + the realtime
# bridge, fronted by the same gateway on VLLM_PORT. Same models the standalone
# realtime-api stack ran — consolidated here, with the bridge's LLM pointed at
# the fleet gateway (no extra vLLM).
#
# CO-RESIDENCE: these share the GPU with the two LLM backends. The base fleet
# already barely co-fits two ~30B NVFP4 models on a GB10 — audio realistically
# wants a dedicated box or a single LLM. See docs/realtime-pipeline.md.

# NGC API key for the Magpie TTS NIM image (https://org.ngc.nvidia.com → Setup).
# Required to pull + run nvcr.io/nim/nvidia/magpie-tts-multilingual.
NGC_API_KEY=

# Internal ports (compose network only; the gateway fronts them on VLLM_PORT).
MAGPIE_TTS_PORT=9000
PARAKEET_PORT=9002
REALTIME_PORT=8080

# Parakeet STT model (NeMo ASR).
PARAKEET_MODEL=nvidia/parakeet-tdt-0.6b-v2

# Host cache for the Magpie NIM artifacts (defaults to ~/.cache/nim).
NIM_CACHE=

# TTS defaults. OpenAI voice names map to Magpie voices (alloy→Mia.Calm,
# echo→Jason.Neutral, fable→Aria.Calm, onyx→Leo.Calm, nova→Mia.Happy,
# shimmer→Aria.Happy); TTS_SPEED is a Magpie percentage (100 = normal).
DEFAULT_VOICE=Mia.Calm
TTS_SPEED=125

# The realtime bridge's LLM is the fleet gateway itself (reuses the warm models,
# no extra vLLM). Leave OPENAI_MODEL empty → the gateway default-routes.
OPENAI_API_KEY=EMPTY
OPENAI_MODEL=

# Gateway → audio backend. The realtime container serves /v1/audio/* (+ the
# /v1/realtime WS in a later release); the gateway path-routes audio here.
AUDIO_URL=http://realtime:8080
