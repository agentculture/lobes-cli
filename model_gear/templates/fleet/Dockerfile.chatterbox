# model-gear Chatterbox TTS sidecar — arm64 GPU container.
#
# `model init --fleet --audio` scaffolds this next to docker-compose.audio.yml,
# which builds it as the `chatterbox` service. Provides the
# GET /v1/health/ready + POST /v1/audio/synthesize HTTP surface consumed by the
# `realtime` bridge (no SSML; returns raw PCM16 mono 24 kHz).
#
# ---------------------------------------------------------------------------
# WHY THIS BASE IMAGE (not NGC pytorch)
# ---------------------------------------------------------------------------
# The NGC nvcr.io/nvidia/pytorch base ships its own torchaudio build whose ABI
# conflicts with the Perth vocoder (resemble-ai/Perth) at runtime — observed as
# a symbol lookup failure when Perth's C extension is imported alongside the NGC
# torchaudio. We therefore start from a lean CUDA runtime image that does NOT
# preinstall torch/torchaudio and install the proven cu128 wheel combo ourselves.
#
# Base: nvidia/cuda:12.8.0-cudnn-runtime-ubuntu24.04
#   - CUDA 12.8 + cuDNN runtime, Ubuntu 24.04 (arm64 tag is available on Docker Hub)
#   - No torch/torchaudio preinstalled — we pin exact versions below
#   - NOTE: verify the arm64 tag exists before building:
#       docker manifest inspect nvidia/cuda:12.8.0-cudnn-runtime-ubuntu24.04
#     A real arm64 GPU build (DGX Spark / on-device `docker build` or
#     `docker buildx build --platform linux/arm64`) is required to validate this
#     image end-to-end; CI is CPU-only x86 and does NOT build this Dockerfile.
# ---------------------------------------------------------------------------
FROM nvidia/cuda:12.8.0-cudnn-runtime-ubuntu24.04
ARG MODEL_GEAR_VERSION

# ---------------------------------------------------------------------------
# System dependencies
# ---------------------------------------------------------------------------
# git  — Perth is installed from a GitHub source URL (--no-deps)
# ffmpeg / libsndfile1 — librosa / soundfile runtime requirements
# libgomp1 — OpenMP runtime required by several audio libs (librosa, torch)
# python3.12 / pip — system Python; cu128 wheels need Python ≥ 3.10
RUN apt-get update && apt-get install -y --no-install-recommends \
        git \
        ffmpeg \
        libsndfile1 \
        libgomp1 \
        python3.12 \
        python3.12-dev \
        python3-pip \
    && rm -rf /var/lib/apt/lists/* \
    && python3.12 -m pip install --no-cache-dir --upgrade pip

# ---------------------------------------------------------------------------
# Install the proven torch 2.11.0+cu128 + torchaudio 2.11.0+cu128 combo.
#
# This is the ONLY torch/torchaudio version validated against Perth on arm64
# Blackwell (DGX Spark). Do NOT change these versions without re-validating
# that Perth's C extension loads without ABI conflicts.
# ---------------------------------------------------------------------------
RUN python3.12 -m pip install --no-cache-dir \
        torch==2.11.0+cu128 \
        torchaudio==2.11.0+cu128 \
        --extra-index-url https://download.pytorch.org/whl/cu128

# ---------------------------------------------------------------------------
# Install Chatterbox and its dependencies.
#
# chatterbox-tts is installed --no-deps to prevent it from pulling in a CPU-only
# or ABI-mismatched torch/torchaudio wheel. All required runtime deps are listed
# explicitly below.
# ---------------------------------------------------------------------------
RUN python3.12 -m pip install --no-cache-dir chatterbox-tts --no-deps \
    && python3.12 -m pip install --no-cache-dir \
        "numpy>=1.24,<2.0" \
        "librosa==0.11.0" \
        "pyloudnorm" \
        "transformers==5.2.0" \
        "diffusers==0.29.0" \
        "conformer==0.3.2" \
        "safetensors==0.5.3" \
        "s3tokenizer" \
        "spacy-pkuseg" \
        "pykakasi==2.3.0" \
        "omegaconf"

# ---------------------------------------------------------------------------
# Install Perth (Resemble AI vocoder) — must come AFTER torch/torchaudio so it
# links against the cu128 ABI we just installed.
# ---------------------------------------------------------------------------
RUN python3.12 -m pip install --no-cache-dir \
        git+https://github.com/resemble-ai/Perth.git --no-deps

# ---------------------------------------------------------------------------
# Install the model-gear server module (provides chatterbox_server entrypoint).
# The [chatterbox] extra adds fastapi + uvicorn.
# ---------------------------------------------------------------------------
RUN python3.12 -m pip install --no-cache-dir "model-gear[chatterbox]==${MODEL_GEAR_VERSION}"

EXPOSE 9000
ENTRYPOINT ["python3.12", "-m", "model_gear.realtime.chatterbox_server"]
