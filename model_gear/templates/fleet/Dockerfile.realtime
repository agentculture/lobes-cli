# model-gear realtime bridge — the audio + speech front of the fleet.
#
# `model init --fleet --audio` scaffolds this next to docker-compose.audio.yml,
# which builds it as the `realtime` service. Mirrors Dockerfile.gateway: install
# model-gear from PyPI and run a packaged entrypoint — but with the [realtime]
# extra (fastapi, uvicorn, httpx, numpy, scipy, silero-vad, torch), which the
# base wheel and the gateway never pull.
#
# MODEL_GEAR_VERSION pins the image to the model-gear release that scaffolded the
# deployment (init --fleet writes the running version into .env). Required.
FROM python:3.12-slim
ARG MODEL_GEAR_VERSION
# One layer: install model-gear[realtime] (system-wide, as root) and create the
# unprivileged runtime user. The bridge binds :8080 internally and makes outbound
# HTTP calls to stt / tts / the gateway on the compose network.
RUN pip install --no-cache-dir "model-gear[realtime]==${MODEL_GEAR_VERSION}" \
    && useradd --create-home --uid 10002 realtime
USER realtime
EXPOSE 8080
ENTRYPOINT ["python", "-m", "model_gear.realtime"]
