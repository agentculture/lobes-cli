# Copy to .env (model init --fleet does this) and adjust. Consumed by the fleet
# docker-compose.yml: two always-warm vLLM backends + a stdlib gateway that
# fronts them on one OpenAI-compatible port.
#
# Both models stay loaded; the gateway routes by the request's `model` field,
# falls back to the default model for an unknown/missing name, and fails over to
# the other backend if the chosen one is down. Keep the two GPU_MEM_UTIL values
# summing well under 1.0 so both fit in the 128 GB unified memory (DGX Spark).
#
# CO-RESIDENCE NEEDS A DEDICATED BOX. Live-validated 2026-05-30: two ~30B NVFP4
# models do NOT co-fit on a GB10 that is *also* running other services — the 27B
# alone takes ~75 GiB at util 0.6, and the fallback then OOMs on load. The values
# below assume a dedicated 128 GB box and are starting estimates — validate live
# (watch `spark memory` / `nvidia-smi`) and lower further on a shared box. See
# docs/gateway-fleet.md "Live validation findings".

# HuggingFace token. Required only for gated repos — accept the license first,
# then paste a read token. Injected into the two vLLM backends, not the gateway.
HF_TOKEN=

# Host path for the HuggingFace weight cache (shared by both backends). Defaults
# to ~/.cache/huggingface (or /root/.cache/huggingface if $HOME is unset).
HF_CACHE=

# --- Primary backend (the gateway's default model) ------------------------
PRIMARY_MODEL=mmangkad/Qwen3.6-27B-NVFP4
PRIMARY_SERVED_NAME=mmangkad/Qwen3.6-27B-NVFP4
PRIMARY_MAX_MODEL_LEN=32768                  # 256K native; cap for the first load, raise with headroom
PRIMARY_GPU_MEM_UTIL=0.40                    # dedicated-box estimate; 0.55 alone took ~75 GiB and OOM'd the fallback
PRIMARY_TOOL_CALL_PARSER=qwen3_coder         # Qwen3.6 emits the Qwen3-Coder XML function format
PRIMARY_QUANTIZATION=modelopt_fp4            # mmangkad/ checkpoint is ModelOpt FP4 (experimental, functional)

# --- Fallback backend (MoE: ~3B active → ~10x faster decode) --------------
FALLBACK_MODEL=mmangkad/Qwen3.6-35B-A3B-NVFP4
FALLBACK_SERVED_NAME=mmangkad/Qwen3.6-35B-A3B-NVFP4
FALLBACK_MAX_MODEL_LEN=32768
FALLBACK_GPU_MEM_UTIL=0.35                    # dedicated-box estimate; the fallback was the one starved at 0.55/0.30
FALLBACK_TOOL_CALL_PARSER=qwen3_coder        # Qwen3.6 emits the XML function format
FALLBACK_QUANTIZATION=modelopt_fp4           # verify for the mmangkad checkpoint (may be compressed-tensors)

# --- Gateway (single front OpenAI endpoint) -------------------------------
# Host port acp/culture.yaml expects → mapped to the gateway. The two backends
# are reachable only on the internal compose network (vllm-primary/vllm-fallback).
VLLM_PORT=8000
GATEWAY_DEFAULT_MODEL=mmangkad/Qwen3.6-27B-NVFP4
# Extra name -> served-name routes, comma-separated (e.g.
# 27b=mmangkad/Qwen3.6-27B-NVFP4,fast=mmangkad/Qwen3.6-35B-A3B-NVFP4).
GATEWAY_ALIASES=
# Short connect timeout (failover-relevant) vs long read timeout (a reasoning
# model's first token is slow — too tight would falsely trip failover).
GATEWAY_CONNECT_TIMEOUT=5
GATEWAY_READ_TIMEOUT=600

# Pins the gateway image to this model-gear release (model init --fleet fills in
# the running version). Required — dev/from-source boxes set a TestPyPI .devN.
MODEL_GEAR_VERSION=

# Coherence mirrors so the read-only verbs (status / whoami / doctor) — which read
# the single-model VLLM_* keys — stay sensible on a fleet deployment. Keep equal
# to PRIMARY_* (the gateway's default).
VLLM_MODEL=mmangkad/Qwen3.6-27B-NVFP4
VLLM_SERVED_NAME=mmangkad/Qwen3.6-27B-NVFP4
VLLM_TOOL_CALL_PARSER=qwen3_coder
