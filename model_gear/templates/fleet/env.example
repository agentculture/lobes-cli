# Copy to .env (model init --fleet does this) and adjust. Consumed by the fleet
# docker-compose.yml: two always-warm vLLM backends + a stdlib gateway that
# fronts them on one OpenAI-compatible port.
#
# Both models stay loaded; the gateway routes by the request's `model` field,
# falls back to the default model for an unknown/missing name, and fails over to
# the other backend if the chosen one is down. Keep the two GPU_MEM_UTIL values
# summing well under 1.0 so both fit in the 128 GB unified memory (DGX Spark).
#
# CO-RESIDENCE NEEDS A DEDICATED BOX. Live-validated 2026-05-30: two ~30B NVFP4
# models do NOT co-fit on a GB10 that is *also* running other services — the 27B
# alone takes ~75 GiB at util 0.6, and the fallback then OOMs on load. The values
# below assume a dedicated 128 GB box and are starting estimates — validate live
# (watch `spark memory` / `nvidia-smi`) and lower further on a shared box. See
# docs/gateway-fleet.md "Live validation findings".

# HuggingFace token. Required only for gated repos — accept the license first,
# then paste a read token. Injected into the two vLLM backends, not the gateway.
# SECURITY: the primary serves with --trust-remote-code (custom modeling code) and
# this token is injected into that container. The default checkpoints are public —
# leave HF_TOKEN empty; for a gated repo use a minimal-scope read-only token.
HF_TOKEN=

# Host path for the HuggingFace weight cache (shared by both backends). Defaults
# to ~/.cache/huggingface (or /root/.cache/huggingface if $HOME is unset).
HF_CACHE=

# --- Primary backend (the gateway's default model) ------------------------
# The MTP speculative-decoding 27B (text-only): ~2.4x decode vs the archived
# baseline, tool calling + reasoning verified 2026-05-31. The MTP serve flags
# (--speculative-config / --trust-remote-code / --language-model-only /
# --tokenizer override) are baked into the fleet compose's vllm-primary service.
PRIMARY_MODEL=sakamakismile/Qwen3.6-27B-Text-NVFP4-MTP
PRIMARY_SERVED_NAME=sakamakismile/Qwen3.6-27B-Text-NVFP4-MTP
PRIMARY_MAX_MODEL_LEN=32768                  # 256K native; kept conservative for co-residence. The single-model deploy serves 128K (load-tested 2026-06-03, ~70 GiB at util 0.6) — but that's solo; the fleet shares 128 GB with the fallback, so 128K here is not yet validated. Raise with headroom.
PRIMARY_GPU_MEM_UTIL=0.40                    # dedicated-box estimate; 0.55 alone took ~75 GiB and OOM'd the fallback
PRIMARY_MAX_NUM_SEQS=2                        # MTP cap — 4 OOMs at n=3/high context (see docs/qwen3.6-27b-text-nvfp4-mtp.md)
PRIMARY_TOOL_CALL_PARSER=qwen3_coder         # Qwen3.6 emits the Qwen3-Coder XML function format
PRIMARY_QUANTIZATION=modelopt                # MTP re-export uses plain `modelopt` (native SM120 NVFP4 path; resolves to modelopt_fp4)

# --- Fallback backend (dense Mistral-Small-3.2-24B, NVFP4) -----------------
# Replaces the Qwen3.6-35B-A3B MoE, which OOM'd/stalled on the GB10 (never
# reached /health — see docs/qwen3.6-35b-a3b-nvfp4.md). Mistral is dense, loads
# reliably (~15 GiB weights, ~15 tok/s decode), and serves text + tool calls. It
# is vision-capable (Mistral3), but the fleet compose serves it with the *mistral*
# tokenizer and images limited to 0 — required for tool-call parsing on this build
# (the HF tokenizer leaks [TOOL_CALLS] markup; the mistral tokenizer alone crashes
# the Pixtral profiler). Text + tools only; see docs/mistral-small-3.2-24b-nvfp4.md.
FALLBACK_MODEL=RedHatAI/Mistral-Small-3.2-24B-Instruct-2506-NVFP4
FALLBACK_SERVED_NAME=RedHatAI/Mistral-Small-3.2-24B-Instruct-2506-NVFP4
FALLBACK_MAX_MODEL_LEN=32768                  # 128K native; cap for the first load, raise with headroom
FALLBACK_GPU_MEM_UTIL=0.35                    # dense 24B NVFP4 (~15 GiB weights); ample headroom at 0.35
FALLBACK_TOOL_CALL_PARSER=mistral             # Mistral emits the [TOOL_CALLS] format
FALLBACK_QUANTIZATION=compressed-tensors      # RedHatAI NVFP4 is compressed-tensors (llm-compressor), not modelopt_fp4
FALLBACK_TOKENIZER_MODE=mistral               # REQUIRED for Mistral tool-call parsing; set `auto` for a non-Mistral fallback
                                              # (the compose also fixes --limit-mm-per-prompt {"image":0} — edit the compose for a text-only fallback)

# --- Gateway (single front OpenAI endpoint) -------------------------------
# Host port acp/culture.yaml expects → mapped to the gateway. The two backends
# are reachable only on the internal compose network (vllm-primary/vllm-fallback).
VLLM_PORT=8000
GATEWAY_DEFAULT_MODEL=sakamakismile/Qwen3.6-27B-Text-NVFP4-MTP
# Extra name -> served-name routes, comma-separated (e.g.
# 27b=sakamakismile/Qwen3.6-27B-Text-NVFP4-MTP,mistral=RedHatAI/Mistral-Small-3.2-24B-Instruct-2506-NVFP4).
GATEWAY_ALIASES=
# Short connect timeout (failover-relevant) vs long read timeout (a reasoning
# model's first token is slow — too tight would falsely trip failover).
GATEWAY_CONNECT_TIMEOUT=5
GATEWAY_READ_TIMEOUT=600

# Pins the gateway image to this model-gear release (model init --fleet fills in
# the running version). Required — dev/from-source boxes set a TestPyPI .devN.
MODEL_GEAR_VERSION=

# Coherence mirrors so the read-only verbs (status / whoami / doctor) — which read
# the single-model VLLM_* keys — stay sensible on a fleet deployment. Keep equal
# to PRIMARY_* (the gateway's default).
VLLM_MODEL=sakamakismile/Qwen3.6-27B-Text-NVFP4-MTP
VLLM_SERVED_NAME=sakamakismile/Qwen3.6-27B-Text-NVFP4-MTP
VLLM_TOOL_CALL_PARSER=qwen3_coder
