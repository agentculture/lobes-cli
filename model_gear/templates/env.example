# Copy to .env (model init does this) and adjust. Consumed by docker-compose.yml.
# This configures the local vLLM model model-gear runs — the model the model-gear
# agent consumes over the acp `vllm-local` provider.

# HuggingFace token. Required only if the model repo is gated — accept its
# license on huggingface.co first, then paste a read token here.
HF_TOKEN=

# Model to download/serve, and the name clients address it by. VLLM_SERVED_NAME
# MUST equal the part after `vllm-local/` in the culture.yaml `model:`
# field, or the acp `vllm-local` provider won't resolve the model.
VLLM_MODEL=mmangkad/Qwen3.6-27B-NVFP4
VLLM_SERVED_NAME=mmangkad/Qwen3.6-27B-NVFP4

# Host port for the OpenAI-compatible API.
VLLM_PORT=8000

# Context window. Qwen3.6-27B is 262144 (256K) native; cap it for the first load
# and raise only with headroom (the KV cache at 256K is large).
VLLM_MAX_MODEL_LEN=32768

# Fraction of the 128 GB unified memory vLLM may reserve. Lower leaves headroom
# for the OS and other mesh agents; raise toward 0.85 on a dedicated box.
# `model switch --machine` sets this from the machine profile (spark 0.6 shared,
# blackwell 0.85 dedicated). Override with `model switch --gpu-mem-util`.
VLLM_GPU_MEM_UTIL=0.6

# --- Tuning profile (purpose + machine) -----------------------------------
# The active gear: which serving purpose and machine `model switch` last resolved.
# Recorded for the read-only verbs (status / whoami / overview) and read by
# `model benchmark` (which defaults its workload shape to VLLM_PURPOSE). Set by
# `model switch --purpose {balanced,prompt-heavy,decode-heavy} --machine
# {auto,spark,thor,blackwell,generic}`. See docs/tuning-profiles.md.
VLLM_PURPOSE=balanced
VLLM_MACHINE=spark

# vLLM attention kernel. flashinfer is the Blackwell-class backend shipped in the
# nv26.04 image; `model switch --machine` writes it from the machine profile.
VLLM_ATTENTION_BACKEND=flashinfer

# vLLM --max-num-seqs (concurrent decode slots) and --max-num-batched-tokens
# (prefill chunk budget). `model switch --purpose` tunes these: balanced 4/8192
# (shahizat's values), prompt-heavy 4/16384, decode-heavy 8/4096.
VLLM_MAX_NUM_SEQS=4
VLLM_MAX_NUM_BATCHED_TOKENS=8192

# Compose-only serve extras: NOT set here — compose can't conditionally omit a
# flag and an empty `--moe-backend=` / `--speculative-config=` token breaks vLLM,
# so `model switch` prints the exact line(s) for a hand edit instead.
#  * MoE (Qwen3.6-35B-A3B): add `--moe-backend=marlin` (verified to load the 35B
#    solo on the GB10). Its MTP `--speculative-config` is NOT carried — it fails on
#    the mmangkad copy. See docs/qwen3.6-35b-a3b-nvfp4.md.
#  * MTP (sakamakismile/Qwen3.6-27B-Text-NVFP4-MTP): add `--speculative-config
#    '{"method":"qwen3_5_mtp","num_speculative_tokens":3}' --trust-remote-code
#    --language-model-only --tokenizer=mmangkad/Qwen3.6-27B-NVFP4` and set
#    VLLM_MAX_NUM_SEQS=2 (4 OOMs at n=3/256K). This MTP-grafted re-export is the only
#    27B that does MTP via vLLM — load-tested on the GB10 at 19.1 tok/s decode
#    (~2.4x the baseline) / 72% acceptance. The --tokenizer override is required (its
#    tokenizer_config declares TokenizersBackend, absent from nv26.04). See
#    docs/qwen3.6-27b-text-nvfp4-mtp.md.

# OpenAI tool-call parser (used with --enable-auto-tool-choice). Qwen3-Coder /
# Qwen3.6 checkpoints (e.g. Qwen3.6-27B) emit the XML function format and need
# `qwen3_coder` (or `qwen3_xml`); `hermes` fits Qwen3 dense models (e.g. Qwen3-32B,
# which emit Hermes-style JSON tool calls). `model switch` auto-selects an
# appropriate parser per model and writes it here; override with `--tool-call-parser`.
VLLM_TOOL_CALL_PARSER=qwen3_coder

# vLLM --quantization for the NVFP4 weights. `modelopt_fp4` fits the nvidia/ and
# mmangkad/ (ModelOpt) checkpoints; RedHatAI NVFP4 (e.g.
# RedHatAI/Mistral-Small-3.2-24B-Instruct-2506-NVFP4) is `compressed-tensors`; the
# sakamakismile MTP re-export uses plain `modelopt` (native SM120 path).
# `model switch` writes this from the catalog (override with `--quantization`).
VLLM_QUANTIZATION=modelopt_fp4

# Host path for the HuggingFace weight cache. Defaults to ~/.cache/huggingface
# (or /root/.cache/huggingface if $HOME is unset). Set to reuse an existing cache
# or to pin a specific disk.
HF_CACHE=
